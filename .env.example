# methodfig environment example.
# Copy this file to .env and fill in the API keys/models you want to use.
# Leave values empty when running with --mock-models.

# Reasoner: creates FigurePlan and PatchPlan JSON.
METHODFIG_REASONER_BASE_URL=
METHODFIG_REASONER_API_KEY=
METHODFIG_REASONER_MODEL=

# Coder: optional model-generated TypeScript path. Generated code is safety-scanned.
METHODFIG_CODER_BASE_URL=
METHODFIG_CODER_API_KEY=
METHODFIG_CODER_MODEL=

# Vision reviewer: reviews rendered PNG previews and returns Review JSON.
METHODFIG_VISION_BASE_URL=
METHODFIG_VISION_API_KEY=
METHODFIG_VISION_MODEL=

# Small asset generation only. Do not use the image model to generate full figures.
# METHODFIG_IMAGE_PROVIDER can be: openrouter, openai_images, replicate, none.
METHODFIG_IMAGE_PROVIDER=
METHODFIG_IMAGE_BASE_URL=
METHODFIG_IMAGE_API_KEY=
METHODFIG_IMAGE_MODEL=

# OpenRouter chat image generation modalities.
# Use "image" for image-only models, or "image,text" for models returning both.
METHODFIG_IMAGE_MODALITIES=
