  "version": "0.1",
  "purpose": "Classic paper method-overview templates derived from PDF/SVG extraction. These are abstract layout templates, not copied figure artwork.",
  "copyright_policy": "Do not paste the extracted source figure as a full-slide image. Use the slots, flows, and visual grammar as editable native PPTX shapes/text/connectors.",
  "selection_rules": [
    {
      "id": "teacher_student_distillation",
      "when_method_mentions": ["teacher", "student", "distillation", "residual"],
      "prefer_template": "simclr_contrastive_y_branch",
      "adaptation": "Treat the shared training input as the SimCLR source, teacher and student as two correlated branches, latent residual or distillation loss as the agreement objective, and inference-only student as a compact post-training note or side output instead of a bottom-heavy separate lane.",
      "avoid": [
        "bottom-heavy separate inference lane",
        "residual as standalone node",
        "floating phase labels",
        "long input detours",
        "standalone inference note component",
        "asymmetric branch annotations",
        "connector-overlapping labels"
      ]
    },
    {
      "id": "encoder_decoder_skip_architecture",
      "when_method_mentions": ["encoder", "decoder", "skip", "multi-scale"],
      "prefer_template": "unet_skip_encoder_decoder",
      "adaptation": "Map contracting modules to encoder stages, bottleneck or latent state to the center valley, expanding modules to decoder stages, and long feature reuse edges to subdued skip connections."
    },
    {
      "id": "diffusion_or_iterative_refinement",
      "when_method_mentions": ["diffusion", "denoise", "reverse process", "iterative refinement"],
      "prefer_template": "ddpm_bidirectional_chain",
      "adaptation": "Use state nodes along a horizontal chain, separate fixed forward/noising references from learned reverse/refinement arrows by style, and keep any thumbnails as small local assets only."
    },
    {
      "id": "stacked_attention_or_seq2seq",
      "when_method_mentions": ["attention", "transformer", "encoder-decoder", "cross attention"],
      "prefer_template": "transformer_encoder_decoder_stack",
      "adaptation": "Use stacked grouped modules with a bridge into the decoder side; collapse repeated layers into grouped blocks for 85 mm paper-width readability."
    }
  ],
